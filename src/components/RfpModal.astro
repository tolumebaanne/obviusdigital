---
// RfpModal.astro
---

<div id="rfp-modal" class="rfp-modal-overlay hidden" aria-hidden="true" role="dialog">
    <div class="rfp-modal-container">
        <button id="rfp-close" class="rfp-close-btn" aria-label="Close modal">&times;</button>
        
        <div class="rfp-modal-header">
            <h2>Request a Proposal</h2>
            <div class="rfp-progress-container">
                <span id="rfp-step-indicator">Step 1 of 5</span>
                <div class="rfp-progress-bar">
                    <div id="rfp-progress-fill" class="rfp-progress-fill"></div>
                </div>
            </div>
        </div>

        <form id="rfp-form" class="rfp-form">
            <!-- STEP 1: Primary Goal -->
            <div class="rfp-step active" data-step="1">
                <fieldset>
                    <legend>What is the primary goal for your digital presence?</legend>
                    <p class="rfp-helper">Choose the one that's most urgent. We'll cover the rest during our call.</p>
                    
                    <label class="rfp-radio">
                        <input type="radio" name="primary_goal" value="Get more local leads/phone calls" required>
                        <span>Get more local leads/phone calls</span>
                    </label>
                    <label class="rfp-radio">
                        <input type="radio" name="primary_goal" value="Refresh an outdated or 'clunky' website">
                        <span>Refresh an outdated or 'clunky' website</span>
                    </label>
                    <label class="rfp-radio">
                        <input type="radio" name="primary_goal" value="Rank higher on Google in my service area">
                        <span>Rank higher on Google in my service area</span>
                    </label>
                    <label class="rfp-radio">
                        <input type="radio" name="primary_goal" value="Launch a brand-new business">
                        <span>Launch a brand-new business</span>
                    </label>
                </fieldset>
            </div>

            <!-- STEP 2: Services -->
            <div class="rfp-step hidden" data-step="2">
                <fieldset>
                    <legend>Which services are you interested in exploring?</legend>
                    <p class="rfp-helper">Not sure yet? Select 'Web Design' and we can audit the rest.</p>
                    
                    <label class="rfp-checkbox">
                        <input type="checkbox" name="services[]" value="Web Design">
                        <span>Web Design</span>
                    </label>
                    <label class="rfp-checkbox">
                        <input type="checkbox" name="services[]" value="SEO">
                        <span>SEO</span>
                    </label>
                    <label class="rfp-checkbox">
                        <input type="checkbox" name="services[]" value="Social Media">
                        <span>Social Media</span>
                    </label>
                    <label class="rfp-checkbox">
                        <input type="checkbox" name="services[]" value="Content/Copywriting">
                        <span>Content/Copywriting</span>
                    </label>
                    <label class="rfp-checkbox">
                        <input type="checkbox" name="services[]" value="Ongoing Maintenance">
                        <span>Ongoing Maintenance</span>
                    </label>
                </fieldset>
            </div>

            <!-- STEP 3: Investment -->
            <div class="rfp-step hidden" data-step="3">
                <fieldset>
                    <legend>What is your estimated investment for this project?</legend>
                    <p class="rfp-helper">
                        <span class="info-icon" title="Note: Most our GTA clients see a full return on their digital investment within the first 6-12 months through increased lead volume.">?</span>
                        This helps us suggest the most effective strategy for your budget.
                    </p>
                    
                    <select name="estimated_investment" class="rfp-select" required>
                        <option value="" disabled selected>Select an option...</option>
                        <option value="$3k - $7k">$3k - $7k: Perfect for local businesses needing a professional presence.</option>
                        <option value="$7k - $15k">$7k - $15k: Ideal for businesses ready to dominate local search and capture more leads.</option>
                        <option value="$15k+">$15k+: Custom solutions for businesses expanding across Ontario.</option>
                        <option value="Not sure">I'm not sure. I'd like a recommendation based on my goals.</option>
                    </select>
                </fieldset>
            </div>

            <!-- STEP 4: Timeline -->
            <div class="rfp-step hidden" data-step="4">
                <fieldset>
                    <legend>How soon are you looking to launch?</legend>
                    <p class="rfp-helper">e.g., "Ready to start Monday" or "Aiming for a summer rebrand"</p>
                    
                    <input type="text" name="launch_timeline" class="rfp-input" placeholder="Your estimated timeline" required>
                </fieldset>
            </div>

            <!-- STEP 5: Contact Details -->
            <div class="rfp-step hidden" data-step="5">
                <fieldset>
                    <legend>Almost done. Where should we send your proposal?</legend>
                    
                    <div class="rfp-field-group">
                        <label for="rfp-name">Full Name*</label>
                        <input type="text" id="rfp-name" name="name" class="rfp-input" placeholder="e.g., John Smith" required>
                    </div>

                    <div class="rfp-field-group">
                        <label for="rfp-business">Business Name*</label>
                        <p class="rfp-helper-small">So we can do some homework on your brand before we chat.</p>
                        <input type="text" id="rfp-business" name="business_name" class="rfp-input" required>
                    </div>

                    <div class="rfp-field-group">
                        <label for="rfp-url">Current Website URL</label>
                        <input type="text" id="rfp-url" name="website_url" class="rfp-input" placeholder="www.yourbusiness.ca">
                    </div>

                    <div class="rfp-field-group">
                        <label for="rfp-email">Email Address*</label>
                        <p class="rfp-helper-small">We'll send your project summary here. No spam, ever.</p>
                        <input type="email" id="rfp-email" name="email" class="rfp-input" required>
                    </div>

                    <div class="rfp-field-group">
                        <label for="rfp-phone">Phone Number*</label>
                        <input type="tel" id="rfp-phone" name="phone_number" class="rfp-input" placeholder="416-555-0123" required>
                    </div>
                </fieldset>
            </div>

            <div id="rfp-error" class="rfp-error hidden">Oops! We need this information to continue.</div>

            <div class="rfp-modal-footer">
                <button type="button" id="rfp-prev" class="rfp-btn-secondary hidden">Back</button>
                <button type="button" id="rfp-next" class="rfp-btn-primary">Next</button>
                <button type="submit" id="rfp-submit" class="rfp-btn-primary hidden">Send My RFP</button>
            </div>
        </form>

        <div id="rfp-success" class="rfp-success hidden">
            <h3>Thanks! We'll reach out to you soon.</h3>
            <button type="button" id="rfp-close-success" class="rfp-btn-secondary mt-1">Close</button>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const modal = document.getElementById('rfp-modal');
        const closeBtn = document.getElementById('rfp-close');
        const closeSuccessBtn = document.getElementById('rfp-close-success');
        const nextBtn = document.getElementById('rfp-next');
        const prevBtn = document.getElementById('rfp-prev');
        const submitBtn = document.getElementById('rfp-submit');
        const form = document.getElementById('rfp-form');
        const successMsg = document.getElementById('rfp-success');
        const errorMsg = document.getElementById('rfp-error');
        const stepIndicator = document.getElementById('rfp-step-indicator');
        const progressFill = document.getElementById('rfp-progress-fill');
        
        const steps = document.querySelectorAll('.rfp-step');
        let currentStep = 1;
        const totalSteps = steps.length;

        // Open modal from any button with data-rfp-trigger attribute or .rfp-trigger class
        const triggers = document.querySelectorAll('.rfp-trigger, [data-rfp-trigger]');
        triggers.forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                modal.classList.remove('hidden');
                modal.setAttribute('aria-hidden', 'false');
                document.body.style.overflow = 'hidden'; // Prevent scrolling
            });
        });

        const closeModal = () => {
            modal.classList.add('hidden');
            modal.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
        };

        closeBtn.addEventListener('click', closeModal);
        closeSuccessBtn.addEventListener('click', closeModal);
        
        // Close on clicking outside container
        modal.addEventListener('click', (e) => {
            if (e.target === modal) closeModal();
        });

        const updateUI = () => {
            steps.forEach((stepEl, idx) => {
                if (idx + 1 === currentStep) {
                    stepEl.classList.remove('hidden');
                    stepEl.classList.add('active');
                } else {
                    stepEl.classList.add('hidden');
                    stepEl.classList.remove('active');
                }
            });

            stepIndicator.textContent = `Step ${currentStep} of ${totalSteps}`;
            progressFill.style.width = `${(currentStep / totalSteps) * 100}%`;

            if (currentStep === 1) {
                prevBtn.classList.add('hidden');
            } else {
                prevBtn.classList.remove('hidden');
            }

            if (currentStep === totalSteps) {
                nextBtn.classList.add('hidden');
                submitBtn.classList.remove('hidden');
            } else {
                nextBtn.classList.remove('hidden');
                submitBtn.classList.add('hidden');
            }

            errorMsg.classList.add('hidden');
        };

        const validateStep = (stepNum) => {
            const stepEl = document.querySelector(`.rfp-step[data-step="${stepNum}"]`);
            
            // For checkboxes (Step 2), at least one must be checked
            const checkboxes = stepEl.querySelectorAll('input[type="checkbox"]');
            if (checkboxes.length > 0) {
                const isChecked = Array.from(checkboxes).some(cb => cb.checked);
                if (!isChecked) return false;
            }

            // Standard HTML5 validation for inputs/selects/radios
            const inputs = stepEl.querySelectorAll('input[required], select[required]');
            for (let input of inputs) {
                if (!input.checkValidity()) {
                    input.reportValidity();
                    return false;
                }
            }
            return true;
        };

        nextBtn.addEventListener('click', () => {
            if (validateStep(currentStep)) {
                currentStep++;
                updateUI();
            } else {
                errorMsg.classList.remove('hidden');
            }
        });

        prevBtn.addEventListener('click', () => {
            currentStep--;
            updateUI();
        });

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            if (!validateStep(currentStep)) {
                errorMsg.classList.remove('hidden');
                return;
            }

            const formData = new FormData(form);
            const dataObj = {};
            
            // Handle arrays (checkboxes)
            formData.forEach((value, key) => {
                if (key.endsWith('[]')) {
                    const cleanKey = key.slice(0, -2);
                    if (!dataObj[cleanKey]) dataObj[cleanKey] = [];
                    dataObj[cleanKey].push(value);
                } else {
                    dataObj[key] = value;
                }
            });

            submitBtn.textContent = 'Sending...';
            submitBtn.disabled = true;

            try {
                const response = await fetch('/contact.php', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(dataObj)
                });

                if (response.ok) {
                    form.classList.add('hidden');
                    successMsg.classList.remove('hidden');
                    // Reset form for future opens
                    form.reset();
                    currentStep = 1;
                    updateUI();
                    form.classList.remove('hidden');
                    successMsg.classList.add('hidden');
                    closeModal();
                    // Optionally show a quick success toast or keep modal open with success message
                    modal.classList.remove('hidden');
                    form.classList.add('hidden');
                    successMsg.classList.remove('hidden');
                } else {
                    throw new Error('Server error');
                }
            } catch (error) {
                console.error(error);
                errorMsg.textContent = 'Something went wrong. Please try again.';
                errorMsg.classList.remove('hidden');
            } finally {
                submitBtn.textContent = 'Send My RFP';
                submitBtn.disabled = false;
            }
        });

        // Initialize UI
        updateUI();
    });
</script>
