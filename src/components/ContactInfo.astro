---
// ContactInfo - CTA paragraph + social media links
import { contact } from '../data/contact.js';
---

<section class="contact-info section">
  <div class="container">
    <span class="section-label">Reach Out</span>
    <h2 class="section-heading">Get in Touch With Us</h2>
    <p class="contact-info__para">
      Ready to grow? We'd love to hear about your business. Reach out however works best for you - we're here as a partner, not just a service.
    </p>
    <div class="social-links" aria-label="Social media links">
      <a href={contact.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Obvius Digital on Instagram">
        📷 Instagram
      </a>
      <a href={contact.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Obvius Digital on Facebook">
        👍 Facebook
      </a>
      <a href={contact.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="Obvius Digital on LinkedIn">
        💼 LinkedIn
      </a>
      <a href={contact.social.youtube} target="_blank" rel="noopener noreferrer" aria-label="Obvius Digital on YouTube">
        ▶ YouTube
      </a>
    </div>
  </div>
</section>
