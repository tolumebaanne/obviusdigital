---
// Founders - message from the founders section
import { founders } from '../data/founders.js';
---

<section class="founders section">
  <div class="container">
    <span class="section-label">A Message From the Founders</span>
    <h2 class="section-heading">The People Behind Obvius</h2>
    <div class="founders__grid">
      {founders.map((founder) => (
        <div class="founder-card">
          <div class="founder-card__photo">
            <img
              src={founder.photo}
              alt={`${founder.name}, Co-Founder of Obvius Digital`}
            />
          </div>
          <h3 class="founder-card__name">{founder.name}</h3>
          <span class="founder-card__title">{founder.title}</span>
          <p class="founder-card__message">
            {founder.message}
          </p>
          <div class="founder-card__socials">
            <a href={founder.instagram} target="_blank" rel="noopener noreferrer" aria-label={`${founder.name} on Instagram`}>Instagram</a>
            <a href={founder.linkedin} target="_blank" rel="noopener noreferrer" aria-label={`${founder.name} on LinkedIn`}>LinkedIn</a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
