---
interface Props {
  serviceName: string;
  body: {
    paragraphs: string[];
    deliverables: string[];
  };
}

const { serviceName, body } = Astro.props;
---

<section class="service-detail section">
  <div class="container">
    <h2 class="service-detail__headline">What {serviceName} Looks Like With Us</h2>
    <div class="service-detail__body">
      {body.paragraphs.map((paragraph) => (
        <p>{paragraph}</p>
      ))}
    </div>

    <div class="service-detail__deliverables">
      <h4>What's Included</h4>
      <ul>
        {body.deliverables.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  </div>
</section>
