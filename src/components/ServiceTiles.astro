---
const services = [
  {
    name: 'Web Design',
    description: 'high-conversion, mobile-first websites tailored for the Ontario market',
    href: '/web-dev',
    icon: '💻',
    linkText: 'View our Work',
  },
  {
    name: '360 Media Production',
    description: 'Video, graphics, and photography that communicate who you are.',
    href: '/production',
    icon: '🎬',
    linkText: 'View Service',
  },
  {
    name: 'SEO & Search Authority',
    description: 'dominate local search results and outrank national competitors in your own backyard',
    href: '/seo',
    icon: '🔍',
    linkText: 'Rank Higher',
  },
  {
    name: 'Digital Marketing',
    description: 'performance-based digital marketing solutions in Toronto, focused on leads, calls, and qualified contracts',
    href: '/digital-marketing',
    icon: '📈',
    linkText: 'Start Growing',
  },
  {
    name: 'Social Media Strategy',
    description: 'create content that engages the heart, building a loyal community around your brand',
    href: '/social-media',
    icon: '📱',
    linkText: 'Get Social',
  },
];
---

<section class="service-tiles section">
  <div class="container">
    <span class="section-label">What We Do</span>
    <h2 class="section-heading">Our Services</h2>
    <p style="color: var(--color-grey-dark); max-width: 60ch; margin-bottom: 2rem; font-size: 1rem;">
      We offer the full spectrum of digital services small businesses need — under one roof, with one team that knows your brand.
    </p>
    <div class="service-tiles__grid">
      {services.map((service) => (
        <div class="service-tile">
          <span class="service-tile__icon" aria-hidden="true">{service.icon}</span>
          <h3 class="service-tile__name">{service.name}</h3>
          <p class="service-tile__desc">{service.description}</p>
          <a href={service.href} class="btn btn--outline-red btn--sm">{service.linkText}</a>
        </div>
      ))}
    </div>
  </div>
</section>
