---
import { services } from '../data/services.js';
---

<section class="service-tiles section">
  <div class="container">
    <span class="section-label">What We Do</span>
    <h2 class="section-heading">Our Services</h2>
    <p style="color: var(--color-grey-dark); max-width: 60ch; margin-bottom: 2rem; font-size: 1rem;">
      We offer the full spectrum of digital services small businesses need - under one roof, with one team that knows your brand.
    </p>
    <div class="service-tiles__grid">
      {services.map((service) => (
        <div class="service-tile">
          <span class="service-tile__icon" aria-hidden="true">{service.icon}</span>
          <h3 class="service-tile__name">{service.name}</h3>
          <p class="service-tile__desc">{service.description}</p>
          <a href={service.href} class="btn btn--outline-red btn--sm">{service.linkText}</a>
        </div>
      ))}
    </div>
  </div>
</section>
