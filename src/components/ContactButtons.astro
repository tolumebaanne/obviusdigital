---
// ContactButtons — 3 big contact buttons (Phone, Email, Instagram DM)
---

<section class="contact-buttons section">
  <div class="container">
    <span class="section-label">Direct Contact</span>
    <h2 class="section-heading">Reach Us Directly</h2>
    <div class="contact-buttons__grid">

      <!-- Phone -->
      <a href="tel:+14168844080" class="contact-btn-block" aria-label="Call Obvius Digital">
        <div class="contact-btn-block__icon" aria-hidden="true">📞</div>
        <div>
          <span class="contact-btn-block__label">Phone</span>
          <p class="contact-btn-block__value">+1 416 884 4080</p>
        </div>
      </a>

      <!-- Email -->
      <a href="mailto:hello@obviusdigital.ca" class="contact-btn-block" aria-label="Email Obvius Digital">
        <div class="contact-btn-block__icon" aria-hidden="true">✉️</div>
        <div>
          <span class="contact-btn-block__label">Email</span>
          <p class="contact-btn-block__value">hello@obviusdigital.ca</p>
        </div>
      </a>

      <!-- Instagram DM -->
      <a
        href="https://instagram.com/obviusdigital"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-btn-block"
        aria-label="Message Obvius Digital on Instagram"
      >
        <div class="contact-btn-block__icon" aria-hidden="true">📷</div>
        <div>
          <span class="contact-btn-block__label">Instagram DM</span>
          <p class="contact-btn-block__value">@obviusdigital</p>
        </div>
      </a>

    </div>
  </div>
</section>
