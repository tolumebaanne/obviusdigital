---
// BackgroundEffect — interactive floating particles
// Visible on both dark and light sections — no blend mode
---

<canvas id="obvius-bg" aria-hidden="true"></canvas>

<style>
  #obvius-bg {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    pointer-events: none;
  }
</style>

<script>
(function () {
  'use strict';

  const canvas = document.getElementById('obvius-bg') as HTMLCanvasElement | null;
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  if (!ctx) return;

  let W = 0, H = 0;

  const mouse = { x: 0, y: 0 };
  const slow  = { x: 0, y: 0 };
  const fast  = { x: 0, y: 0 };

  function resize() {
    W = canvas!.width  = window.innerWidth;
    H = canvas!.height = window.innerHeight;
    mouse.x = slow.x = fast.x = W * 0.5;
    mouse.y = slow.y = fast.y = H * 0.5;
  }
  window.addEventListener('resize', resize, { passive: true });
  resize();

  window.addEventListener('mousemove', (e: MouseEvent) => {
    mouse.x = e.clientX;
    mouse.y = e.clientY;
  }, { passive: true });

  // Five types — mix of light, dark and brand so some are always visible
  // regardless of whether the underlying section is dark or light
  type Colour = [number, number, number, number];
  const PALETTE: Colour[] = [
    [255, 255, 255, 0.22],  // white       — stands out on dark sections
    [ 30,  30,  30, 0.18],  // near-black  — stands out on light sections
    [192,  57,  43, 0.20],  // brand red   — visible on both
    [180, 180, 180, 0.18],  // light grey  — soft on dark sections
    [ 60,  60,  60, 0.16],  // mid-grey    — soft on light sections
  ];

  interface Dot {
    x: number; y: number;
    vx: number; vy: number;
    r: number;
    col: Colour;
  }

  function makeDot(): Dot {
    return {
      x:  Math.random() * W,
      y:  Math.random() * H,
      vx: (Math.random() - 0.5) * 0.35,
      vy: (Math.random() - 0.5) * 0.35,
      r:  Math.random() * 2.5 + 1.2,   // 1.2 – 3.7 px radius
      col: PALETTE[Math.floor(Math.random() * PALETTE.length)],
    };
  }

  function stepDot(d: Dot) {
    const dx   = fast.x - d.x;
    const dy   = fast.y - d.y;
    const dist = Math.hypot(dx, dy) || 1;
    const pull = Math.max(0, 1 - dist / 440) * 0.003;
    d.vx += (dx / dist) * pull;
    d.vy += (dy / dist) * pull;
    d.vx *= 0.988;
    d.vy *= 0.988;
    d.x  += d.vx;
    d.y  += d.vy;
    if (d.x < -8)    d.x = W + 8;
    if (d.x > W + 8) d.x = -8;
    if (d.y < -8)    d.y = H + 8;
    if (d.y > H + 8) d.y = -8;
  }

  function drawDot(d: Dot) {
    const [r, g, b, a] = d.col;
    // Soft halo around each particle
    ctx!.shadowBlur  = 6;
    ctx!.shadowColor = `rgba(${r},${g},${b},0.4)`;
    ctx!.beginPath();
    ctx!.arc(d.x, d.y, d.r, 0, Math.PI * 2);
    ctx!.fillStyle = `rgba(${r},${g},${b},${a})`;
    ctx!.fill();
    ctx!.shadowBlur = 0;
  }

  const dots: Dot[] = Array.from({ length: 75 }, makeDot);

  let raf: number | null = null;

  function render() {
    ctx!.clearRect(0, 0, W, H);

    slow.x += (mouse.x - slow.x) * 0.025;
    slow.y += (mouse.y - slow.y) * 0.025;
    fast.x += (mouse.x - fast.x) * 0.06;
    fast.y += (mouse.y - fast.y) * 0.06;

    // Soft brand-red radial glow that follows the cursor
    const g = ctx!.createRadialGradient(slow.x, slow.y, 0, slow.x, slow.y, 360);
    g.addColorStop(0,    'rgba(192, 57, 43, 0.10)');
    g.addColorStop(0.5,  'rgba(192, 57, 43, 0.04)');
    g.addColorStop(1,    'rgba(192, 57, 43, 0)');
    ctx!.fillStyle = g;
    ctx!.fillRect(0, 0, W, H);

    for (const d of dots) {
      stepDot(d);
      drawDot(d);
    }

    raf = requestAnimationFrame(render);
  }

  render();

  document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
      if (raf !== null) { cancelAnimationFrame(raf); raf = null; }
    } else if (raf === null) {
      render();
    }
  });
}());
</script>
