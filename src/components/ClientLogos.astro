---
// ClientLogos - client/partner logo strip
// NOTE: Confirm with Tolu before launch which of the larger brands (Pearson, BAT, GE, Red Bull)
// should be included - these may be past employer/academic associations vs. direct client work.

import { clientLogos as logos } from '../data/clientLogos.js';
---

<section class="client-logos">
  <div class="container">
    <p class="client-logos__label"><span style="color: var(--color-red);">TRUSTED</span> by businesses like yours</p>
    <div class="client-logos__strip">
      {logos.map((logo) => (
        <img
          src={logo.src}
          alt={logo.alt}
          class="client-logo-img"
          loading="lazy"
        />
      ))}
    </div>
  </div>
</section>

