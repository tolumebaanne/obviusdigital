---
// HomeHero - homepage hero section
---

<section class="home-hero">
  <div class="container home-hero__inner">
    <span class="home-hero__eyebrow">Obvius Digital</span>
    <h1 class="home-hero__heading">
      Building the Digital Future for <em>Toronto’s Independent Businesses.</em>
    </h1>
    <p class="home-hero__subtext">
      Stop losing local leads to outdated tech. We build high-performing websites and SEO strategies that turn Ontario searchers into your next big contract. Get started with a free 15-minute site audit.
    </p>
    <div class="home-hero__ctas">
      <a href="/contact" class="btn btn--primary rfp-trigger">Request Proposal</a>
      <a href="#services" class="btn btn--outline">Learn More</a>
    </div>

    <!-- Work examples strip -->
    <div class="home-hero__work-strip">
      <span class="home-hero__work-label">Some of our work</span>
      <div class="home-hero__work-cards" id="home-hero-work-cards"></div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', async () => {
    const cardsEl = document.getElementById('home-hero-work-cards');
    if (!cardsEl) return;

    const escapeHtml = str => String(str).replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    const escapeAttr = str => JSON.stringify(str).replace(/'/g, '&#39;');

    const render = works => {
      cardsEl.innerHTML = works.slice(0, 3).map(work => `
        <button type="button" class="hero-work-card" data-work-trigger data-work='${escapeAttr(work)}'>
          <span class="hero-work-card__cat">${escapeHtml(work.category || '')}</span>
          <span class="hero-work-card__name">${escapeHtml(work.brandName || '')}</span>
        </button>
      `).join('');
    };

    try {
      let works = await fetch('/works-feed.php?page=home').then(r => r.json()).then(d => d.works || []);
      // Nothing pinned to the homepage yet — fall back to the most recent published work
      if (works.length === 0) {
        works = await fetch('/works-feed.php').then(r => r.json()).then(d => d.works || []);
      }
      render(works);
    } catch (err) {
      console.error(err);
    }
  });
</script>
