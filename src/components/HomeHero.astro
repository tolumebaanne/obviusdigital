---
// HomeHero — homepage hero section
---

<section class="home-hero">
  <div class="container home-hero__inner">
    <span class="home-hero__eyebrow">Obvius Digital</span>
    <h1 class="home-hero__heading">
      More than marketing. <em>A partner in your growth.</em>
    </h1>
    <p class="home-hero__subtext">
      We help small and medium-sized businesses show up with confidence, communicate clearly, and grow intentionally.
    </p>
    <div class="home-hero__ctas">
      <a href="/contact" class="btn btn--primary">Request Proposal</a>
      <a href="#services" class="btn btn--outline">Learn More</a>
    </div>

    <!-- Work examples strip -->
    <div class="home-hero__work-strip">
      <span class="home-hero__work-label">Some of our work</span>
      <div class="home-hero__work-cards">
        <div class="hero-work-card">
          <span class="hero-work-card__cat">[PLACEHOLDER]</span>
          <span class="hero-work-card__name">[PLACEHOLDER] Project Name</span>
        </div>
        <div class="hero-work-card">
          <span class="hero-work-card__cat">[PLACEHOLDER]</span>
          <span class="hero-work-card__name">[PLACEHOLDER] Project Name</span>
        </div>
        <div class="hero-work-card">
          <span class="hero-work-card__cat">[PLACEHOLDER]</span>
          <span class="hero-work-card__name">[PLACEHOLDER] Project Name</span>
        </div>
      </div>
    </div>
  </div>
</section>
