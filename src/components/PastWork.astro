---
const works = [
  {
    brandName: '[PLACEHOLDER] Brand Name',
    category: '[PLACEHOLDER] Category',
  },
  {
    brandName: '[PLACEHOLDER] Brand Name',
    category: '[PLACEHOLDER] Category',
  },
  {
    brandName: '[PLACEHOLDER] Brand Name',
    category: '[PLACEHOLDER] Category',
  },
];
---

<section class="past-work section">
  <div class="container">
    <span class="section-label">Our Work</span>
    <h2 class="section-heading">A Few Things We've Built</h2>
    <p style="color: var(--color-grey-dark); max-width: 60ch; margin-bottom: 2rem; font-size: 1rem;">
      Every project we take on reflects the brand behind it. Here are some examples of what we've delivered.
    </p>
    <div class="past-work__grid">
      {works.map((work) => (
        <div class="work-card">
          <div class="work-card__logo-area">
            <span class="work-card__logo-placeholder">[PLACEHOLDER] Client Logo</span>
          </div>
          <span class="work-card__tag">{work.category}</span>
          <h3 class="work-card__name">{work.brandName}</h3>
        </div>
      ))}
    </div>
  </div>
</section>
