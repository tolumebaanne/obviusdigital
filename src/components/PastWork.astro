---
---

<section class="past-work section">
  <div class="container">
    <span class="section-label">Our Work</span>
    <h2 class="section-heading">A Few Things We've Built</h2>
    <p class="section-intro">
      Every project we take on reflects the brand behind it. Here are some examples of what we've delivered.
    </p>
    <div class="past-work__filters" id="past-work-filters"></div>
    <div class="past-work__grid" id="past-work-grid">
      <p class="past-work__status" id="past-work-status">Loading our work&hellip;</p>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', async () => {
    const filtersEl = document.getElementById('past-work-filters');
    const grid = document.getElementById('past-work-grid');
    const status = document.getElementById('past-work-status');
    if (!grid) return;

    const escapeHtml = str => String(str).replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    const escapeAttr = str => JSON.stringify(str).replace(/'/g, '&#39;');

    let works = [];
    const urlCategory = new URLSearchParams(window.location.search).get('category');
    let activeCategory = urlCategory || 'All';

    const updateUrl = () => {
      const url = new URL(window.location.href);
      if (activeCategory === 'All') {
        url.searchParams.delete('category');
      } else {
        url.searchParams.set('category', activeCategory);
      }
      history.replaceState(null, '', url);
    };

    const renderCards = () => {
      const filtered = activeCategory === 'All' ? works : works.filter(w => w.category === activeCategory);

      if (filtered.length === 0) {
        grid.innerHTML = '<p class="past-work__status">No work in this category yet.</p>';
        return;
      }

      grid.innerHTML = filtered.map(work => {
        const thumbnail = work.thumbnail || (Array.isArray(work.images) && work.images.length ? work.images[0] : '');
        const brandName = escapeHtml(work.brandName || '');
        const category = escapeHtml(work.category || '');
        return `
          <button type="button" class="work-card" data-work-trigger data-work='${escapeAttr(work)}'>
            <div class="work-card__logo-area">
              <img src="${escapeHtml(thumbnail)}" alt="${brandName} project photo" class="work-card__logo" loading="lazy">
            </div>
            <span class="work-card__tag">${category}</span>
            <h3 class="work-card__name">${brandName}</h3>
          </button>
        `;
      }).join('');
    };

    const renderFilters = () => {
      const categories = ['All', ...new Set(works.map(w => w.category).filter(Boolean))];
      if (categories.length <= 2) {
        // Not worth showing a filter bar for zero or one real category
        filtersEl.innerHTML = '';
        return;
      }
      filtersEl.innerHTML = categories.map(cat => `
        <button type="button" class="past-work__filter-btn${cat === activeCategory ? ' past-work__filter-btn--active' : ''}" data-category="${escapeHtml(cat)}">${escapeHtml(cat)}</button>
      `).join('');
    };

    filtersEl.addEventListener('click', e => {
      const btn = e.target.closest('[data-category]');
      if (!btn) return;
      activeCategory = btn.dataset.category;
      updateUrl();
      renderFilters();
      renderCards();
    });

    try {
      const res = await fetch('/works-feed.php');
      if (!res.ok) throw new Error('Feed request failed');
      const data = await res.json();
      works = Array.isArray(data.works) ? data.works : [];

      if (works.length === 0) {
        if (status) status.textContent = "We're adding our latest work here soon — check back shortly.";
        return;
      }

      renderFilters();
      renderCards();
    } catch (err) {
      console.error(err);
      if (status) status.textContent = "We couldn't load our work right now — please refresh or check back shortly.";
    }
  });
</script>
