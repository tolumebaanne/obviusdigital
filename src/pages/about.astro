---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import AboutContent from '../components/AboutContent.astro';
import WhyUsGrid from '../components/WhyUsGrid.astro';
import Founders from '../components/Founders.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="About Us - Obvius Digital"
  description="Obvius Digital was founded by Tolu Mebaanne and Kayla Sippel. We help small and medium-sized businesses grow with intention."
>
  <Header slot="header" />

  <PageHero
    label="About Obvius Digital"
    heading="We're More Than a Marketing Agency."
    tagline="We're the team that learns your brand and stays invested in what happens after the work is done."
  >
    <div class="about-hero-media">
      <img
        src="/images/pexels-mikael-blomkvist-6476254.jpg"
        alt="The Obvius Digital team collaborating"
      />
    </div>
  </PageHero>

  <AboutContent />
  <WhyUsGrid />
  <Founders />
  <ContactForm />

  <Footer slot="footer" />
</BaseLayout>
