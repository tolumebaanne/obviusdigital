---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import AboutContent from '../components/AboutContent.astro';
import WhyUsGrid from '../components/WhyUsGrid.astro';
import Founders from '../components/Founders.astro';
import Reviews from '../components/Reviews.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="About Us — Obvius Digital"
  description="Obvius Digital was founded by Tolu Mebaanne and Kayla Sippel. We help small and medium-sized businesses grow with intention."
>
  <Header slot="header" />

  <PageHero
    label="About Obvius Digital"
    heading="We're More Than a Marketing Agency."
    tagline="We're the team that learns your brand and stays invested in what happens after the work is done."
  >
    <div style="margin-top: 2rem; width: 100%; height: 200px; background: rgba(255,255,255,0.04); border-radius: 8px; border: 1px dashed rgba(255,255,255,0.1); display: flex; align-items: center; justify-content: center;">
      <span style="color: rgba(255,255,255,0.25); font-size: 0.8125rem; letter-spacing: 0.08em; text-transform: uppercase;">[PLACEHOLDER] Hero Graphic</span>
    </div>
  </PageHero>

  <AboutContent />
  <WhyUsGrid />
  <Founders />
  <Reviews />
  <ContactForm />

  <Footer slot="footer" />
</BaseLayout>
