---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import PastWork from '../components/PastWork.astro';
import WorkModal from '../components/WorkModal.astro';
import WorkCTA from '../components/WorkCTA.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="Our Work - Obvius Digital"
  description="Past work and case studies from Obvius Digital. Media production, digital marketing, websites, and more for small and medium-sized businesses."
>
  <Header slot="header" />

  <PageHero
    label="Our Work"
    heading="Built With Intention."
    tagline="A look at some of the projects we've had the privilege of working on."
  />

  <PastWork />
  <WorkModal />
  <WorkCTA />
  <ContactForm />

  <Footer slot="footer" />
</BaseLayout>
